{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*", "src/**/*.vue", "env.d.ts", "vite.config.mjs"],
  "exclude": ["node_modules", "dist"],
  "vueCompilerOptions": {
    "target": 3.5
  }
}
